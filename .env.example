# ════════════════════════════════════════
#  EXCHANGE CONFIG
# ════════════════════════════════════════
EXCHANGE=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# ════════════════════════════════════════
#  TRADING CONFIG
# ════════════════════════════════════════
SYMBOL=BTC/USDT
TIMEFRAME=1m
PAPER_TRADING=true          # true = simulation, false = réel

# ════════════════════════════════════════
#  RISK MANAGEMENT
# ════════════════════════════════════════
CAPITAL=1000                # Capital initial en USDT
RISK_PER_TRADE=1.5          # % du capital risqué par trade
MAX_TRADES_PER_SESSION=5    # Limite trades par session
STOP_LOSS_PCT=0.4           # Stop loss en %
TAKE_PROFIT_1_PCT=0.6       # TP1 en %
TAKE_PROFIT_2_PCT=1.2       # TP2 en %

# ════════════════════════════════════════
#  INDICATEURS
# ════════════════════════════════════════
EMA_FAST=9
EMA_SLOW=21
EMA_TREND=50
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
ATR_PERIOD=14

# ════════════════════════════════════════
#  TELEGRAM ALERTS (optionnel)
# ════════════════════════════════════════
TELEGRAM_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ALERTS=false
